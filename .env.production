# Production Environment Variables
# This file is used when building for production (npm run build)

# Backend API URL - UPDATE THIS after deploying backend
REACT_APP_API_URL=https://your-backend-url.onrender.com/api

# Instructions:
# 1. Deploy your backend first (see DEPLOYMENT_GUIDE.md)
# 2. Replace "your-backend-url.onrender.com" with your actual backend URL
# 3. Make sure the URL ends with /api
# 4. Example: https://organic-food-backend.onrender.com/api
